<div class="container py-4">

    {{!-- Search Panel --}}
    <div class="katcon-search-panel mb-4">
        <div class="katcon-search-panel__header">
            <div class="katcon-search-panel__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 3h18M3 9h18M3 15h12M3 21h8"/>
                </svg>
            </div>
            <div>
                <div class="katcon-search-panel__title">Ver Registros</div>
                <div class="katcon-search-panel__sub">Consulta los últimos registros de la base de datos</div>
            </div>
        </div>

        <div class="katcon-search-panel__body">
            <div class="katcon-search-panel__section-label">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
                </svg>
                PARÁMETROS DE BÚSQUEDA
            </div>
            <div class="katcon-search-panel__row">
                <div class="katcon-search-panel__field">
                    <div class="katcon-search-panel__field-label">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <path d="M3 3h18M3 9h12M3 15h8"/>
                        </svg>
                        CANTIDAD DE REGISTROS
                    </div>
                    <input
                        type="number"
                        autofocus
                        class="katcon-search-panel__input"
                        id="cantidadAbuscar"
                        placeholder="Ej. 100"
                        min="1"
                        value="{{cantidadBuscada}}"
                    >
                </div>
                <button class="katcon-search-panel__btn" id="buscarRegistros">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
                    </svg>
                    Buscar
                </button>
            </div>
        </div>
    </div>

    {{!-- Tabla --}}
    {{#if cantidadBuscada}}
    <div class="katcon-table-wrap">
        <table id="tablaConsulta" class="table table-hover table-bordered mb-0">
            <thead>
                <tr>
                    <th>Serial</th>
                    <th>Repetida</th>
                    <th>Uso</th>
                    <th>Fecha Creación</th>
                    <th>Escaneo GP-12</th>
                    <th>Escaneo Polonia</th>
                </tr>
            </thead>
            <tbody>
                {{#each etiqueta}}
                <tr>
                    <td><strong>{{this.serial}}</strong></td>
                    <td>
                        {{#if this.repetida}}
                            <span class="bs-badge bs-badge--si">Sí</span>
                        {{else}}
                            <span class="bs-badge bs-badge--no">No</span>
                        {{/if}}
                    </td>
                    <td>{{#if this.uso_etiqueta}}{{this.uso_etiqueta}}{{else}}<span class="text-muted">—</span>{{/if}}</td>
                    <td><small>{{formatDate this.createdAt}}</small></td>
                    <td><small>{{formatDate this.fecha_gp12}}</small></td>
                    <td><small>{{formatDate this.fechapolonia}}</small></td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
    {{/if}}

</div>
