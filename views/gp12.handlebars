{{!-- ══ GP-12 ══ --}}
<div class="fa-page">

  {{!-- ── PAGE HEADER ── --}}
  <div class="fa-header">
    <div class="fa-header__left">
      <div class="fa-header__icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M9 12l2 2 4-4"/>
          <path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>
        </svg>
      </div>
      <div>
        <h1 class="fa-header__title">Sistema GP-12</h1>
        <p class="fa-header__sub">Inspección y verificación de etiquetas</p>
      </div>
    </div>
  </div>

  {{!-- ── MAIN GRID ── --}}
  <div class="gp-grid">

    {{!-- ── COLUMNA IZQUIERDA: Scanner + Tabla ── --}}
    <div class="gp-left">

      {{!-- Scanner --}}
      <div class="fa-card" style="margin-bottom:16px;">
        <div class="fa-card__head">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15">
            <rect x="2" y="4" width="3" height="16" rx="1"/>
            <rect x="7" y="4" width="2" height="16" rx="1"/>
            <rect x="11" y="4" width="4" height="16" rx="1"/>
            <rect x="17" y="4" width="2" height="16" rx="1"/>
            <rect x="21" y="4" width="1" height="16" rx="1"/>
          </svg>
          Escanear Etiqueta
        </div>
        <div class="fa-card__body">
          <div class="fa-scanner">
            <input type="text" class="fa-scanner__input" autofocus
              id="serialEtiqueta" placeholder="Escanea o ingresa el serial…"
              inputmode="numeric">
            <button class="fa-scanner__btn" type="button" id="submit">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="15" height="15">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              Revisar
            </button>
          </div>

          {{!-- Resultado inline --}}
          <div id="gp-resultado" class="gp-resultado" style="display:none;"></div>
        </div>
      </div>

      {{!-- Últimas 6 etiquetas --}}
      <div class="fa-card">
        <div class="fa-card__head">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
          </svg>
          Últimas 6 Etiquetas
        </div>
        <div class="fa-card__body fa-card__body--flush">
          <table class="fa-table fa-table--serial">
            <thead>
              <tr>
                <th>Serial</th>
                <th style="text-align:center">Estatus</th>
                <th>Fecha GP-12</th>
              </tr>
            </thead>
            <tbody id="tablaDe6"></tbody>
          </table>
        </div>
      </div>

    </div>

    {{!-- ── COLUMNA DERECHA: Resultado grande ── --}}
    <div class="gp-right">
      <div class="fa-card gp-result-card" id="gp-result-card">
        <div class="fa-card__head">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 8v4l3 3"/>
          </svg>
          Resultado
        </div>
        <div class="fa-card__body gp-result-body" id="gp-result-body">
          <div class="gp-idle">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" width="52" height="52" opacity=".25">
              <rect x="2" y="4" width="3" height="16" rx="1"/>
              <rect x="7" y="4" width="2" height="16" rx="1"/>
              <rect x="11" y="4" width="4" height="16" rx="1"/>
              <rect x="17" y="4" width="2" height="16" rx="1"/>
              <rect x="21" y="4" width="1" height="16" rx="1"/>
            </svg>
            <p style="color:var(--slate-400); font-size:.85rem; margin-top:12px;">
              Escanea una etiqueta para ver el resultado
            </p>
          </div>
        </div>
      </div>
    </div>

  </div>{{!-- /gp-grid --}}

</div>{{!-- /fa-page --}}

{{!-- ── Modal cambio de número de parte ── --}}
<div class="modal fade" id="exampleModal" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" role="document">
    <div class="modal-content" style="border-radius:16px; border:1.5px solid var(--slate-200);">
      <div class="modal-header" style="border-bottom:1px solid var(--slate-100);">
        <h5 class="modal-title" style="font-family:'Sora',sans-serif; font-weight:700; font-size:1rem;">
          ⚠️ NP Diferente Detectado
        </h5>
        <button type="button" class="close" data-dismiss="modal">
          <span>&times;</span>
        </button>
      </div>
      <div class="modal-body" style="font-family:'DM Sans',sans-serif; font-size:.9rem; color:var(--slate-600); line-height:1.6;">
        El número de parte de la etiqueta anterior y la nueva <strong>no coinciden</strong>. 
        No pueden ir mezcladas en la misma caja. Verifica que vayan en cajas separadas. 
        Si es anormal, avisa al Ing. de Calidad y pon las piezas en cuarentena.
      </div>
      <div class="modal-footer" style="border-top:1px solid var(--slate-100);">
        <button type="button" class="btn btn-secondary" data-dismiss="modal"
          style="border-radius:8px; font-family:'DM Sans',sans-serif;">Entendido</button>
      </div>
    </div>
  </div>
</div>

<style>
  /* ── Layout grid GP12 ── */
  .gp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    align-items: start;
  }
  @media (max-width: 768px) {
    .gp-grid { grid-template-columns: 1fr; }
    .gp-right { order: -1; } /* resultado arriba en móvil */
  }

  .gp-result-card { min-height: 320px; }
  .gp-result-body {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 260px;
    flex-direction: column;
    text-align: center;
    padding: 32px 24px;
  }

  .gp-idle { display: flex; flex-direction: column; align-items: center; }

  /* ── Estados de resultado ── */
  .gp-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    animation: gpFadeIn .35s ease;
  }
  @keyframes gpFadeIn { from { opacity:0; transform:scale(.92); } to { opacity:1; transform:scale(1); } }

  .gp-state__icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .gp-state__icon--ok     { background: #dcfce7; color: #16a34a; }
  .gp-state__icon--error  { background: #fee2e2; color: #dc2626; }
  .gp-state__icon--warn   { background: #fef9c3; color: #ca8a04; }

  .gp-state__title {
    font-family: 'Sora', sans-serif;
    font-weight: 800;
    font-size: 1.25rem;
  }
  .gp-state__title--ok    { color: #16a34a; }
  .gp-state__title--error { color: #dc2626; }
  .gp-state__title--warn  { color: #ca8a04; }

  .gp-state__msg {
    font-family: 'DM Sans', sans-serif;
    font-size: .88rem;
    color: var(--slate-500);
    max-width: 280px;
    line-height: 1.5;
  }

  .gp-segregar-btn {
    margin-top: 8px;
    padding: 10px 24px;
    border-radius: 10px;
    border: none;
    background: #dc2626;
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: .88rem;
    cursor: pointer;
    transition: background .18s;
  }
  .gp-segregar-btn:hover { background: #b91c1c; }

  [data-theme="dark"] .gp-state__icon--ok    { background: rgba(34,197,94,.15); color: #4ade80; }
  [data-theme="dark"] .gp-state__icon--error { background: rgba(220,38,38,.15); color: #f87171; }
  [data-theme="dark"] .gp-state__icon--warn  { background: rgba(234,179,8,.15); color: #facc15; }
  [data-theme="dark"] .gp-state__title--ok   { color: #4ade80; }
  [data-theme="dark"] .gp-state__title--error{ color: #f87171; }
  [data-theme="dark"] .gp-state__title--warn { color: #facc15; }
  [data-theme="dark"] .modal-content { background: var(--slate-800); border-color: var(--slate-700); }
  [data-theme="dark"] .modal-body, [data-theme="dark"] .modal-header { color: var(--slate-300); border-color: var(--slate-700); }
</style>
