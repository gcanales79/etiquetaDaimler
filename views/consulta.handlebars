<div class="container py-4">

    {{!-- Tarjeta de búsqueda --}}
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h5 class="card-title mb-3">Consulta de Etiqueta por Número de Serie</h5>
            <div class="form-group">
                <label for="numeroDeserie" class="font-weight-bold">Número de Serie</label>
                <input
                    type="text"
                    autofocus
                    class="form-control form-control-lg"
                    id="numeroDeserie"
                    placeholder="Ej. 247490980368260603943"
                    value="{{serialBuscado}}"
                >
                <small class="form-text text-muted">No. de Serie de la Etiqueta</small>
            </div>
            <div class="d-flex align-items-center">
                <button class="btn btn-primary px-4 mr-2" id="buscarSerial">
                    Buscar
                </button>
                {{#if serialBuscado}}
                <a href="/consulta" class="btn btn-outline-secondary">Limpiar</a>
                {{/if}}
            </div>
        </div>
    </div>

    {{!-- Resultados --}}
    {{#if serialBuscado}}
        {{#if etiqueta.length}}
            <p class="text-muted small mb-2">
                {{etiqueta.length}} resultado(s) para: <strong>{{serialBuscado}}</strong>
            </p>
        {{/if}}
    {{/if}}

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="tablaConsulta" class="table table-hover table-bordered mb-0">
                    <thead class="thead-light">
                        <tr>
                            <th>Id</th>
                            <th>Serial</th>
                            <th>Repetida</th>
                            <th>Reemplazo a</th>
                            <th>Uso</th>
                            <th>Fecha Creación</th>
                            <th>Escaneo GP-12</th>
                            <th>Escaneo Polonia</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each etiqueta}}
                        <tr>
                            <td>{{this.id}}</td>
                            <td><strong>{{this.serial}}</strong></td>
                            <td>
                                {{#if this.repetida}}
                                    <span class="badge badge-danger">Sí</span>
                                {{else}}
                                    <span class="badge badge-success">No</span>
                                {{/if}}
                            </td>
                            <td>{{#if this.etiqueta_remplazada}}{{this.etiqueta_remplazada}}{{else}}—{{/if}}</td>
                            <td>{{#if this.uso_etiqueta}}{{this.uso_etiqueta}}{{else}}—{{/if}}</td>
                            <td>{{formatDate this.createdAt}}</td>
                            <td>{{formatDate this.fecha_gp12}}</td>
                            <td>{{formatDate this.fechapolonia}}</td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {{!-- Mensaje sin resultados --}}
    {{#if serialBuscado}}
        {{#unless etiqueta.length}}
        <div class="text-center py-5 text-muted">
            <i class="fa fa-inbox fa-3x mb-3"></i>
            <h5>Sin Resultados</h5>
            <p>No se encontró ninguna etiqueta con el serial <strong>{{serialBuscado}}</strong>.</p>
        </div>
        {{/unless}}
    {{/if}}

</div>
