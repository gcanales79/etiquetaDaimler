{{!-- ══ ALTA DE LÍNEAS ══ --}}
<div class="fa-page">

  {{!-- ── PAGE HEADER ── --}}
  <div class="fa-header">
    <div class="fa-header__left">
      <div class="fa-header__icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <line x1="8" y1="6" x2="21" y2="6"/>
          <line x1="8" y1="12" x2="21" y2="12"/>
          <line x1="8" y1="18" x2="21" y2="18"/>
          <line x1="3" y1="6" x2="3.01" y2="6"/>
          <line x1="3" y1="12" x2="3.01" y2="12"/>
          <line x1="3" y1="18" x2="3.01" y2="18"/>
        </svg>
      </div>
      <div>
        <h1 class="fa-header__title">Líneas de Producción</h1>
        <p class="fa-header__sub">Gestión de líneas registradas</p>
      </div>
    </div>
    <button type="button" id="addLine" class="fa-scanner__btn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Agregar Línea
    </button>
  </div>

  {{!-- ── TABLE CARD ── --}}
  <div class="fa-card">
    <div class="fa-card__body fa-card__body--flush">
      <table class="fa-table">
        <thead>
          <tr>
            <th style="width:80%">Línea</th>
            <th style="width:20%; text-align:center">Acciones</th>
          </tr>
        </thead>
        <tbody id="lineList"></tbody>
      </table>
    </div>
  </div>

  {{!-- ── PAGINATION ── --}}
  <div class="alta-pagination">
    <div class="paginationjs" id="pagination-containerLine"></div>
  </div>

</div>

{{>modalAdmin}}
{{>modalLine}}
