<div class="container">
  <div class="row">
    <div class="col-md-6 col-md-offset-3">
      <h2>Entrada Sistema de Etiquetas</h2>
      <form class="login" method="post" action="/login">
        <div class="form-group">
          <label for="exampleInputEmail1">Correo</label>
          <input type="email" class="form-control" name="email" id="email-input" placeholder="Email" required>
        </div>
        <div class="form-group">
          <label for="exampleInputPassword1">Password</label>
          <input type="password" class="form-control" name="password" id="password-input" placeholder="Password" required>
        </div>
        <button type="submit" class="btn btn-primary">Login</button>
      </form>
      <br />

    </div>
  </div>
  {{#if error}}
  <div class="row">
    <div class="col-md-6 col-md-offset-3">
      <div class="alert alert-danger">{{error}}</div>
    </div>
  </div>
  {{/if}}
   {{#if success}}
  <div class="row">
    <div class="col-md-6 col-md-offset-3">
      
      <div class="alert alert-success">{{success}}</div>
    </div>
  </div>
  {{/if}}
  <div>
    <a href="#" data-toggle="modal" data-target="#recoveryModal">Olvide Contraseña</a>
  </div>

  <!-- Modal -->
  <div class="modal fade" id="exampleModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="exampleModalLabel">Restablecer Contraseña</h5>
          <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body">
          <div class="row">
            <div class="col-md-12">
              <form action="/forgot" method="POST">
                <legend>Olvide Contraseña</legend>
                <div class="form-group">
                  <label for="email">Correo</label>
                  <input type="email" name="email" autofocus class="form-control">
                </div>
                <div class="form-group">
                  <input type="submit" class="btn btn-primary" value="Restablecer Contraseña">
                </div>
              </form>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
        </div>
      </div>
    </div>
  </div>

  <div class="modal fade" id="recoveryModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title">Recover Password</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                
                <div id="recoveryAlert" class="alert d-none" role="alert"></div>

                <div id="step1-email">
                    <p>Enter your registered email address to receive a WhatsApp verification code.</p>
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" class="form-control" id="recoveryEmail" placeholder="user@domain.com" required>
                    </div>
                    <button type="button" class="btn btn-primary btn-block mt-3" id="btnSendRecoveryCode">
                        Send WhatsApp Code
                    </button>
                </div>

                <div id="step2-reset" class="d-none">
                    <p class="text-success">✅ Code sent to your registered WhatsApp number.</p>
                    <div class="form-group">
                        <label>6-Digit Code</label>
                        <input type="text" class="form-control" id="recoveryOtp" placeholder="123456" maxlength="6" required>
                    </div>
                    <div class="form-group mt-2">
                        <label>New Password</label>
                        <input type="password" class="form-control" id="newPassword" placeholder="Enter new password" required>
                    </div>
                    <button type="button" class="btn btn-success btn-block mt-3" id="btnResetPassword">
                        Reset Password
                    </button>
                </div>

            </div>
        </div>
    </div>
</div>





</div>




