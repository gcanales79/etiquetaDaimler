{{!-- This view uses the blank layout (no navbar/footer) --}}

<div class="login-page">
  <div class="login-card">

    {{!-- Logo --}}
    <a href="/" class="login-logo">
      <div class="login-logo-mark">K</div>
      <span class="login-logo-text">Katcon</span>
    </a>

    {{!-- Header --}}
    <div class="login-header">
      <div class="login-eyebrow">Bienvenido</div>
      <h1 class="login-title">Inicia sesión en tu cuenta</h1>
      <p class="login-subtitle">Ingresa tus credenciales para acceder al sistema.</p>
    </div>

    {{!-- Server-side alerts (flash messages) --}}
    {{#if error}}
      <div class="login-alert error">{{error}}</div>
    {{/if}}
    {{#if success}}
      <div class="login-alert success">{{success}}</div>
    {{/if}}

    {{!-- JS alert (filled by login.js) --}}
    <div class="login-alert" id="loginAlert"></div>

    {{!-- Form --}}
    <form id="loginForm" novalidate>

      <div class="field-group">
        <label for="email">Correo electrónico</label>
        <div class="input-wrap">
          <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="2" y="4" width="20" height="16" rx="2.5"/>
            <path d="M2 7.5l10 6.5 10-6.5"/>
          </svg>
          <input type="email" class="form-control" id="email" name="email"
            placeholder="usuario@empresa.com" required autocomplete="email">
        </div>
      </div>

      <div class="field-group">
        <label for="password">Contraseña</label>
        <div class="input-wrap">
          <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="5" y="11" width="14" height="10" rx="2"/>
            <path d="M8 11V7a4 4 0 0 1 8 0v4"/>
            <circle cx="12" cy="16" r="1" fill="currentColor"/>
          </svg>
          <input type="password" class="form-control" id="password" name="password"
            placeholder="••••••••" required autocomplete="current-password">
        </div>
      </div>

      <button type="submit" class="btn-login" id="loginBtn">
        Iniciar Sesión
      </button>

    </form>

    <div class="forgot-row">
      <a href="#" class="forgot-link" id="openRecovery">¿Olvidaste tu contraseña?</a>
    </div>

    <div class="login-footer">
      <img src="/images/Logo_netzwerk.png" width="90" height="52" alt="Netzwerk">
    </div>

  </div>
</div>

{{!-- ══ RECOVERY MODAL ══ --}}
<div class="modal-overlay" id="recoveryOverlay">
  <div class="modal-card">
    <button class="modal-close" id="closeModal">&times;</button>

    {{!-- Step 1: Enter email --}}
    <div class="modal-step active" id="step1">
      <div class="modal-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
      </div>
      <div class="modal-title">Recuperar Contraseña</div>
      <p class="modal-desc">Ingresa tu correo registrado y te enviaremos un código de verificación por WhatsApp.</p>

      <div class="login-alert" id="alert1"></div>

      <div class="field-group">
        <label for="recoveryEmail">Correo electrónico</label>
        <div class="input-wrap">
          <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="2" y="4" width="20" height="16" rx="2.5"/>
            <path d="M2 7.5l10 6.5 10-6.5"/>
          </svg>
          <input type="email" class="form-control" id="recoveryEmail" placeholder="usuario@empresa.com">
        </div>
      </div>

      <button class="modal-btn primary" id="btnSendCode">Enviar código por WhatsApp</button>
    </div>

    {{!-- Step 2: OTP + new password --}}
    <div class="modal-step" id="step2">
      <div class="modal-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <rect x="5" y="11" width="14" height="10" rx="2"/>
          <path d="M8 11V7a4 4 0 0 1 8 0v4"/>
        </svg>
      </div>
      <div class="modal-title">Nueva Contraseña</div>

      <div class="sent-banner">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
          <path d="M22 4L12 14.01l-3-3"/>
        </svg>
        Código enviado a tu WhatsApp registrado.
      </div>

      <div class="login-alert" id="alert2"></div>

      <div class="field-group">
        <label for="otpCode">Código de verificación (6 dígitos)</label>
        <div class="input-wrap">
          <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          <input type="text" class="form-control" id="otpCode"
            placeholder="123456" maxlength="6" inputmode="numeric">
        </div>
      </div>

      <div class="field-group">
        <label for="newPassword">Nueva contraseña</label>
        <div class="input-wrap">
          <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="5" y="11" width="14" height="10" rx="2"/>
            <path d="M8 11V7a4 4 0 0 1 8 0v4"/>
          </svg>
          <input type="password" class="form-control" id="newPassword" placeholder="Mínimo 5 caracteres">
        </div>
      </div>

      <button class="modal-btn primary" id="btnReset">Restablecer contraseña</button>
      <button class="modal-btn ghost" id="btnBack">← Volver</button>
    </div>

  </div>
</div>
